# ChronoSeek Subnet Configuration
# Copy this file to .env and update the values.

# Chain
# Bittensor network to connect to: finney, test, or local.
NETWORK=finney
# Subnet netuid on the selected network.
NETUID=1

# Wallet
# Coldkey wallet name used by miner/validator commands.
WALLET_NAME=default
# Hotkey name registered on the subnet.
HOTKEY_NAME=default
# Path to local Bittensor wallet storage.
WALLET_PATH=~/.bittensor/wallets

# Chutes
# Chutes API token used for runtime build/deploy and private runtime requests.
CHUTES_API_KEY=
# Base domain used to resolve miner chute_slug submissions.
CHUTES_BASE_DOMAIN=chutes.ai
# Minimum validator stake accepted by the Chutes runtime /search endpoint.
MIN_VALIDATOR_STAKE=10000

# Miner Video Download
# Optional absolute path to a Netscape cookies.txt file for yt-dlp authenticated downloads.
YTDLP_COOKIES=
# Optional browser cookie source for yt-dlp, for example chrome or firefox:Default.
YTDLP_COOKIES_BROWSER=
# Optional Node.js runtime path for yt-dlp EJS challenge solving.
YTDLP_NODE_PATH=
# Optional Deno runtime path for yt-dlp EJS challenge solving.
YTDLP_DENO_PATH=

# Hugging Face
# Hugging Face token used for ActivityNet and model downloads.
HF_TOKEN=hf_your_token_here
# Hugging Face cache directory.
HF_HOME=~/.cache/huggingface
# Optional ActivityNet JSON filename override inside the downloaded snapshot.
HF_ACTIVITYNET_FILENAME=

# Validator Task Generation
# Optional local ActivityNet-style manifest path. If unset, the validator uses the configured HF source/bootstrap path.
TASK_DATASET_PATH=
# Dataset split used for validator task sampling.
TASK_SPLIT=validation
# Require validator tasks to use videos that pass an accessibility check before querying miners.
REQUIRE_ACCESSIBLE_VIDEOS=1
# Max attempts to sample an accessible validator task before falling back to cached accessible videos.
TASK_MAX_SAMPLING_ATTEMPTS=50

# Validator Video Availability Cache
# Optional legacy base cache path used to derive accessible/inaccessible cache paths when specific paths are unset.
VIDEO_AVAILABILITY_CACHE_PATH=
# Optional JSON cache path for videos confirmed accessible by the validator.
ACCESSIBLE_VIDEO_CACHE_PATH=
# Optional JSON cache path for videos confirmed inaccessible by the validator.
INACCESSIBLE_VIDEO_CACHE_PATH=
# TTL for validator video availability cache entries.
VIDEO_AVAILABILITY_CACHE_TTL_HOURS=24
# Timeout in seconds for validator-side video accessibility checks.
VIDEO_AVAILABILITY_TIMEOUT=20

# Validator Evaluation
# Per-miner timeout in seconds for validator runtime /search requests.
MINER_REQUEST_TIMEOUT_SECONDS=150
# Cache TTL in seconds for loaded miner metadata submissions.
MINER_SUBMISSION_CACHE_TTL_SECONDS=300
# Interval in seconds between validator submission metadata refreshes.
MINER_SUBMISSION_REFRESH_INTERVAL_SECONDS=60
# Per-runtime timeout in seconds for responsive miner /health checks.
MINER_SUBMISSION_HEALTH_TIMEOUT_SECONDS=10
# Percent of miner emissions to burn by assigning weight to UID 0.
MINER_EMISSION_BURN_PERCENT=0

# Logging
# Logging verbosity: DEBUG, INFO, WARNING, or ERROR.
LOG_LEVEL=INFO
