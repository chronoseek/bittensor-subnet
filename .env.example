# ChronoSeek Subnet Configuration
# Copy this file to .env and update the values

# Network Configuration
NETWORK=finney          # finney (mainnet), test (testnet), or local
NETUID=1                # Your subnet's netuid

# Wallet Configuration
WALLET_NAME=default     # Name of your wallet
HOTKEY_NAME=default     # Name of your hotkey
WALLET_PATH=~/.bittensor/wallets # Path to your wallet storage

# Miner Configuration
PORT=8000                   # Port for the miner's HTTP server
ALLOWED_VALIDATOR_HOTKEYS=  # Comma-separated whitelist of validator hotkeys

# Hugging Face (Required for model downloads)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Logging
LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR
