# ChronoSeek Subnet Configuration
# Copy this file to .env and update the values

# Network Configuration
NETWORK=finney          # finney (mainnet), test (testnet), or local
NETUID=1                # Your subnet's netuid

# Wallet Configuration
WALLET_NAME=default     # Name of your wallet
HOTKEY_NAME=default     # Name of your hotkey
WALLET_PATH=~/.bittensor/wallets # Path to your wallet storage

# Miner Configuration
MIN_VALIDATOR_STAKE=10000   # Minimum stake required by the Chutes runtime /search endpoint

CHRONOSEEK_YTDLP_COOKIES=   # Optional absolute path to Netscape cookies.txt for YouTube auth
CHRONOSEEK_YTDLP_COOKIES_BROWSER=  # Optional browser profile source (e.g. chrome or firefox:Default)
CHRONOSEEK_YTDLP_NODE_PATH=  # Optional Node.js runtime path (Node 22+ recommended for yt-dlp EJS)
CHRONOSEEK_YTDLP_DENO_PATH=  # Optional Deno runtime path (Deno 2+ recommended for yt-dlp EJS)

# Hugging Face (Required for model downloads)
HF_TOKEN=hf_your_token_here     # Get your token at: https://huggingface.co/settings/tokens

HF_HOME=~/.cache/huggingface    # Optional
HF_ACTIVITYNET_FILENAME=        # Optional

# Validator Configuration
ENABLE_SYNTHETIC_EVALUATION=1  # Enable synthetic validator scoring and weight updates by default
SYNTHETIC_MINER_TIMEOUT_SECONDS=150  # Per-miner timeout for synthetic validator evaluation fanout
MINER_SUBMISSION_CACHE_TTL_SECONDS=300
MINER_SUBMISSION_REFRESH_INTERVAL_SECONDS=60 # Interval between validator submission metadata refreshes
MINER_SUBMISSION_HEALTH_TIMEOUT_SECONDS=10 # Per-runtime timeout for responsive miner /health checks
CHUTES_BASE_DOMAIN=chutes.ai  # Base domain used to resolve chute_slug submissions
CHRONOSEEK_CHUTES_API_KEY=    # Optional provider auth token for private Chutes eval requests
MINER_EMISSION_BURN_PERCENT=0  # Percent of miner emissions to burn by assigning weight to UID 0
## Task Generation
TASK_DATASET_PATH=                      # Optional
TASK_SPLIT=validation
REQUIRE_ACCESSIBLE_VIDEOS=1
TASK_MAX_SAMPLING_ATTEMPTS=50
VIDEO_AVAILABILITY_CACHE_PATH=          # Optional legacy base path used to derive the two cache files below
ACCESSIBLE_VIDEO_CACHE_PATH=            # Optional
INACCESSIBLE_VIDEO_CACHE_PATH=          # Optional
VIDEO_AVAILABILITY_CACHE_TTL_HOURS=24
VIDEO_AVAILABILITY_TIMEOUT=20
# Logging
LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR
