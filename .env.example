# ChronoSeek Subnet Configuration
# Copy this file to .env and update the values

# Network Configuration
NETWORK=finney          # finney (mainnet), test (testnet), or local
NETUID=1                # Your subnet's netuid

# Wallet Configuration
WALLET_NAME=default     # Name of your wallet
HOTKEY_NAME=default     # Name of your hotkey
WALLET_PATH=~/.bittensor/wallets # Path to your wallet storage

# Miner Configuration
PORT=8000                   # Default value for bittensor's axon.port
MIN_VALIDATOR_STAKE=10000   # Minimum stake requirement

# Hugging Face (Required for model downloads)
HF_TOKEN=hf_your_token_here ## Get your token at: https://huggingface.co/settings/tokens

HF_HOME=~/.cache/huggingface    # Optional
HF_ACTIVITYNET_FILENAME=        # Optional

# Validator Task Generation
TASK_DATASET_PATH=                      # Optional
TASK_SPLIT=validation
REQUIRE_ACCESSIBLE_VIDEOS=1
TASK_MAX_SAMPLING_ATTEMPTS=50
VIDEO_AVAILABILITY_CACHE_PATH=          # Optional
VIDEO_AVAILABILITY_CACHE_TTL_HOURS=24
VIDEO_AVAILABILITY_TIMEOUT=20

# Logging
LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR
